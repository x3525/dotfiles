@theme "theme.rasi"
@import "keyboard.rasi"
@import "mouse.rasi"

configuration {
    auto-select: false;
    case-sensitive: false;
    click-to-exit: true;
    disable-history: false;
    dpi: 0;
    drun-display-format: "{name}";
    drun-match-fields: "all";
    font: "JetBrains Mono 12";
    hover-select: false;
    icon-theme: "Papirus";
    matching: "normal";
    max-history-size: 5;
    monitor: -1;
    normalize-match: false;
    scroll-method: 0;
    sidebar-mode: false;
    window-format: "{t:0}";
    window-match-fields: "all";

    entry {
        max-history: 0;
    }

    window {
        close-on-delete: false;
        hide-active-window: false;
        prefer-icon-theme: false;
    }
}
