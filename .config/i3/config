include config.d/*.conf

# Screen locker
exec --no-startup-id xss-lock --transfer-sleep-lock -- C2 lock

# Executing applications
exec_always --no-startup-id C2 execute ~/.config/autostart/desktop.d

focus_follows_mouse no

mouse_warping output

popup_during_fullscreen smart

focus_wrapping yes

force_xinerama no

workspace_auto_back_and_forth no

focus_on_window_activation urgent

tiling_drag off
