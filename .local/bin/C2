#!/bin/bash

LOCK()
{
    dunstctl set-paused true

    i3lock -n -c 000000 -p default -e -f -k

    dunstctl set-paused false
}

NOTIFY()
{
    case $1 in
        B)
            case $3 in
                0)
                    ICON=battery-000
                    ;;
                [1-9])
                    ICON=battery-010
                    ;;
                [1-9]?)
                    ICON=battery-0${3:0:1}0
                    ;;
                100)
                    ICON=battery-100
                    ;;
            esac
            case $2 in
                C)
                    notify-send -u low -h string:x-dunst-stack-tag:battery -i "$ICON"-charging "BATTERY CHARGING"
                    ;;
                D)
                    notify-send -u critical -h string:x-dunst-stack-tag:battery -i "$ICON" "BATTERY DISCHARGING"
                    ;;
                F)
                    notify-send -h string:x-dunst-stack-tag:battery "notification-ignore"
                    ;;
                N)
                    notify-send -h string:x-dunst-stack-tag:battery "notification-ignore"
                    ;;
                U)
                    notify-send -u critical -h string:x-dunst-stack-tag:battery -i battery-missing "BATTERY STATUS UNKNOWN"
                    ;;
            esac
            ;;
        V)
            pamixer -"$2" "$3" --allow-boost --set-limit=150 && killall -s USR1 i3status

            if pamixer --get-mute | grep -q true
            then
                ICON=volume-level-none
            else
                ICON=volume-level-high
            fi

            notify-send -u low -h string:x-dunst-stack-tag:volume -i "$ICON" "" -h int:value:"$(pamixer --get-volume)"
            ;;
    esac
}

RESTART()
{
    for d in "$1"/*
    do
        f=$(basename -- "$d")

        p=${f%.*}

        killall -q -- "$p"

        while pgrep -u "$(id -u)" -x "$p" > /dev/null
        do
            sleep 1
        done
    done

    dex -a -s "$1"
}

$1 "${@:2}"
