#!/bin/bash

brightness () {
    command brightnessctl set "$2"%"$1"
}

lock () {
    command dunstctl set-paused true

    command i3lock -n -c 000000 -p default -e -f -k &

    wait

    command dunstctl set-paused false
}

menu () {
    command rofi -no-lazy-grab -show "$1" -modes "$1" -theme "$1"
}

notify () {
    case $1 in
        battery)
            case $3 in
                0)
                    CAPACITY=000
                    ;;
                [1-9])
                    CAPACITY=010
                    ;;
                [1-9]?)
                    CAPACITY=0${3:0:1}0
                    ;;
                100)
                    CAPACITY=100
                    ;;
            esac
            case $2 in
                C)
                    command notify-send -h string:x-dunst-stack-tag:battery -u low -i battery-"$CAPACITY"-charging "battery" "battery is charging"
                    ;;
                D)
                    command notify-send -h string:x-dunst-stack-tag:battery -u critical -i battery-"$CAPACITY" "battery" "battery is discharging"
                    ;;
                F)
                    command notify-send -h string:x-dunst-stack-tag:battery -u low "honorificabilitudinitatibus"
                    ;;
                N)
                    command notify-send -h string:x-dunst-stack-tag:battery -u low "honorificabilitudinitatibus"
                    ;;
                U)
                    command notify-send -h string:x-dunst-stack-tag:battery -u critical -i battery-missing "battery" "battery status unknown"
                    ;;
            esac
            ;;
        volume)
            command pamixer -"$2" "$3" --allow-boost --set-limit=150

            command killall -s USR1 i3status

            if command pamixer --get-mute | command grep -q true
            then
                ICON=volume-level-none
            else
                ICON=volume-level-high
            fi

            command notify-send -h string:x-dunst-stack-tag:volume -u low -i "$ICON" "" -h int:value:"$(command pamixer --get-volume)"
            ;;
    esac
}

execute () {
    for d in "$1"/*
    do
        f=$(command basename -- "$d")

        p=${f%.*}

        command killall -q -- "$p"

        while command pgrep -u "$(command id -u)" -x "$p"
        do
            command sleep 1
        done
    done

    command dex -a -s "$1"
}

$1 "${@:2}"
