@import "keyboard.rasi"
@import "mouse.rasi"
@theme "theme.rasi"

configuration {
    disable-history: false;
    dpi: 0;
    drun-display-format: "{name}";
    icon-theme: "Papirus";
    max-history-size: 10;
    modi: "drun,power";
    monitor: -1;
    sidebar-mode: false;

    entry {
        max-history: 0;
    }
}
