{
    "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
    "blocks": [
        {
            "alignment": "left",
            "newline": false,
            "segments": [
                {
                    "foreground": "blue",
                    "foreground_templates": [
                        "{{ if not .Writable }}red{{ end }}"
                    ],
                    "properties": {
                        "folder_separator_icon": "/",
                        "home_icon": "~",
                        "style": "full"
                    },
                    "style": "plain",
                    "template": "{{ .Path }}",
                    "type": "path"
                },
                {
                    "foreground": "green",
                    "properties": {
                        "branch_ahead_icon": ">",
                        "branch_behind_icon": "<",
                        "branch_gone_icon": "",
                        "branch_icon": "",
                        "branch_identical_icon": "",
                        "branch_template": "{{ .Branch }}",
                        "cherry_pick_icon": "",
                        "commit_icon": "",
                        "fetch_bare_info": true,
                        "fetch_status": true,
                        "fetch_upstream_icon": false,
                        "fetch_user": false,
                        "merge_icon": "",
                        "no_commits_icon": "",
                        "rebase_icon": "",
                        "revert_icon": "",
                        "source": "cli",
                        "tag_icon": ""
                    },
                    "style": "plain",
                    "template": " {{ .HEAD }}{{ if .BranchStatus }} <magenta>{{ .BranchStatus }}</>{{ end }}{{ if .Staging.Changed }} <yellow>{{ .Staging.String }}</>{{ end }}{{ if .Working.Changed }} <blue>{{ .Working.String }}</>{{ end }}",
                    "type": "git"
                }
            ],
            "type": "prompt"
        },
        {
            "alignment": "right",
            "newline": false,
            "overflow": "break",
            "segments": [
                {
                    "foreground": "red",
                    "properties": {
                        "always_enabled": false,
                        "status_separator": "|",
                        "status_template": "{{ .Code }}"
                    },
                    "style": "plain",
                    "template": "{{ .String }} ",
                    "type": "status"
                },
                {
                    "foreground": "yellow",
                    "style": "plain",
                    "template": "{{ if gt .Jobs 0 }}& {{ end }}",
                    "type": "text"
                },
                {
                    "foreground": "magenta",
                    "properties": {
                        "command": "ip -j -o -4 address show | jq -r '.[] | .addr_info[] | select(.dev | test(\"(gpd|wg|(.*tun)|tailscale)[0-9]*|(zt.*)\")) | .dev' | paste -s -d ' '",
                        "interpret": true,
                        "shell": "bash"
                    },
                    "style": "plain",
                    "template": "{{ .Output }} ",
                    "type": "command"
                },
                {
                    "foreground": "cyan",
                    "properties": {
                        "cache_duration": "none",
                        "display_default": true,
                        "display_mode": "environment",
                        "fetch_version": true,
                        "fetch_virtual_env": true,
                        "folder_name_fallback": false,
                        "home_enabled": true
                    },
                    "style": "plain",
                    "template": "{{ .Venv }} ",
                    "type": "python"
                },
                {
                    "foreground": "blue",
                    "properties": {
                        "command": "pyenv version-name",
                        "interpret": true,
                        "shell": "bash"
                    },
                    "style": "plain",
                    "template": "{{ .Output }}",
                    "type": "command"
                }
            ],
            "type": "prompt"
        },
        {
            "alignment": "left",
            "newline": true,
            "segments": [
                {
                    "foreground": "cyan",
                    "style": "plain",
                    "template": "{{ if .Root }}<red>#</>{{ else }}${{ end }}",
                    "type": "text"
                }
            ],
            "type": "prompt"
        }
    ],
    "final_space": true,
    "version": 3
}
